{
  "expo": {
    "name": "Pivot Paths",
    "slug": "pivot-paths",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pivotpaths",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "A guided career transition app for dancers navigating what comes next.",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.isaaccavallaro.pivotpaths"
    },
    "android": {
      "package": "com.isaaccavallaro.pivotpaths"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router", "expo-font", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
